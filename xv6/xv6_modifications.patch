diff -uprN xv6-original/schedulertest.c xv6-modified/schedulertest.c
--- xv6-original/schedulertest.c	1970-01-01 00:00:00.000000000 +0000
+++ xv6-modified/schedulertest.c	2025-09-11 03:48:19.824896816 +0000
@@ -0,0 +1,42 @@
+#include "types.h"
+#include "stat.h"
+#include "user.h"
+
+void busy_loop(char id) {
+    // A long loop to consume CPU time
+    for (long i = 0; i < 200000000; i++) {
+        if (i % 50000000 == 0) {
+            // Print periodically to show progress
+            printf(1, "%c", id);
+        }
+    }
+}
+
+int main(void) {
+    printf(1, "Starting scheduler test...\n");
+
+    if (fork() == 0) {
+        // Child 1
+        busy_loop('A');
+        exit();
+    }
+
+    if (fork() == 0) {
+        // Child 2
+        busy_loop('B');
+        exit();
+    }
+
+    if (fork() == 0) {
+        // Child 3
+        busy_loop('C');
+        exit();
+    }
+
+    // Parent waits for all three children
+    wait();
+    wait();
+    wait();
+    printf(1, "\nScheduler test finished.\n");
+    exit();
+}
\ No newline at end of file
